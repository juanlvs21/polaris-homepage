# =============================================================================
#  .env.example — variables de entorno (secretos)
# =============================================================================
#  Copia a `.env` y rellena. Estos valores se referencian en config.yaml con la
#  sintaxis ${VAR_NAME}. NUNCA versiones tu `.env` real.
# =============================================================================

# Puerto público del dashboard en producción (docker-compose)
DASHBOARD_PORT=80

# --- Proxmox API Tokens ------------------------------------------------------
# Crear en Proxmox: Datacenter > Permissions > API Tokens.
# Asigna rol PVEAuditor (solo lectura) al token.
PROXMOX_NODE1_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PROXMOX_NODE2_TOKEN=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- Arcane API Key ----------------------------------------------------------
# Generar en la UI de Arcane > Settings > API Keys.
ARCANE_API_KEY=your-arcane-api-key
ARCANE_MEDIA_API_KEY=your-second-arcane-api-key
